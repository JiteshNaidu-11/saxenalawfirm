<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Keep direct requests to real files/folders unchanged.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback so /admin and other routes load React app.
  RewriteRule ^ index.html [L]
</IfModule>

